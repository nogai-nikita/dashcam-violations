# Copy to .env and edit. Both paths are absolute host paths.

# The dumped dashcam SD card (mounted read-only into the worker).
SD_MOUNT=/run/media/nick/DASHCAM

# Where ingested clips, manifests, and the dedup ledger are written.
DATA_DIR=/home/nick/Projects/dashcam-violations/data

# Run the worker as your host user so files in DATA_DIR are yours, not root's.
# Set to the output of `id -u` / `id -g` (1000 is the typical first user).
HOST_UID=1000
HOST_GID=1000
